# Bustly OAuth configuration for desktop client login
# Web 端地址：用于登录页面跳转
BUSTLY_WEB_BASE_URL=https://www.bustly.shop
# BUSTLY_WEB_BASE_URL=http://localhost:5174
# Optional: renderer from CDN (Electron shell + preload only)
BUSTLY_RENDERER_URL=https://www.bustly.shop/client-app

# API 端地址：用于 token 交换 API 调用
BUSTLY_API_BASE_URL=https://gateway.bustly.shop
BUSTLY_CLIENT_ID=bustly-desktop
OPENCLAW_CONFIG_PATH=~/.bustly/openclaw.json
OPENCLAW_STATE_DIR=~/.bustly
BUSTLY_UPDATE_BASE_URL=https://www-salerio-global.oss-us-west-1.aliyuncs.com/static/

# 模型网关地址
BUSTLY_MODEL_GATEWAY_BASE_URL=https://gw.bustly.ai/api/v1

BUSTLY_WORKSPACE_TEMPLATE_BASE_URL=https://raw.githubusercontent.com/salerio-ai/bustly-prompts/main/openclaw-prompts
