# Bustly OAuth configuration for desktop client login
# Web 端地址：用于登录页面跳转
BUSTLY_WEB_BASE_URL=https://test-www.bustly.shop
# BUSTLY_WEB_BASE_URL=http://localhost:5174

# API 端地址：用于 token 交换 API 调用
BUSTLY_API_BASE_URL=https://test.agent-api.bustly.shop/java
BUSTLY_CLIENT_ID=openclaw-desktop

# 测试环境 model-gateway 直连地址
BUSTLY_MODEL_GATEWAY_BASE_URL=https://test-gw.bustly.ai/api/v1

# 测试环境 telemetry-ingest
OPENCLAW_TELEMETRY_INGEST_BASE_URL=http://18.141.16.138
OPENCLAW_TELEMETRY_INGEST_KEY=replace-with-openclaw-ingest-key
OPENCLAW_TELEMETRY_INGEST_SERVICE_NAME=openclaw
OPENCLAW_TELEMETRY_INGEST_TIMEOUT_MS=3000
