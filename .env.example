# OpenClaw .env example
#
# Quick start:
# 1) Copy this file to `.env` (for shared defaults), OR to `~/.openclaw/.env`
#    when you want machine-local overrides.
# 2) Fill only the values you use.
# 3) Keep real secrets out of git.
#
# Env-source precedence for environment variables (highest -> lowest):
# process env, ./.env.<OPENCLAW_ENV>.local, ./.env.<OPENCLAW_ENV>, ./.env.local,
# ./.env, ~/.openclaw/.env.<OPENCLAW_ENV>.local, ~/.openclaw/.env.<OPENCLAW_ENV>,
# ~/.openclaw/.env.local, ~/.openclaw/.env, then openclaw.json `env` block.
# Existing non-empty process env vars are not overridden by dotenv/config env loading.
# Note: direct config keys (for example `gateway.auth.token` or channel tokens in openclaw.json)
# are resolved separately from env loading and often take precedence over env fallbacks.

# Optional environment selector. The repo root now supports:
# - `.env`
# - `.env.test`
# - `.env.production`
# plus `.env.local` / `.env.<env>.local` overlays if you need them.
# OPENCLAW_ENV=test

# -----------------------------------------------------------------------------
# Gateway auth + paths
# -----------------------------------------------------------------------------
# Recommended if the gateway binds beyond loopback.
OPENCLAW_GATEWAY_TOKEN=change-me-to-a-long-random-token
# Example generator: openssl rand -hex 32

# Optional alternative auth mode (use token OR password).
# OPENCLAW_GATEWAY_PASSWORD=change-me-to-a-strong-password

# Optional path overrides (defaults shown for reference).
# OPENCLAW_STATE_DIR=~/.openclaw
# OPENCLAW_CONFIG_PATH=~/.openclaw/openclaw.json
# OPENCLAW_HOME=~

# Optional: import missing keys from your login shell profile.
# OPENCLAW_LOAD_SHELL_ENV=1
# OPENCLAW_SHELL_ENV_TIMEOUT_MS=15000

# -----------------------------------------------------------------------------
# Bustly + Cloud Runtime environment (optional)
# -----------------------------------------------------------------------------
# Put these in the existing repo-root `.env` when running Bustly Cloud locally or
# when invoking the ECS helper scripts from this repo. If you need machine-local
# secrets, use `~/.openclaw/.env` instead of adding more tracked files.
#
# Business environment
# OPENCLAW_BUSTLY_PROFILE=test
# BUSTLY_API_BASE_URL=https://test-bustly-account.bustly.ai/api
# BUSTLY_WEB_BASE_URL=https://test-www.bustly.shop
# BUSTLY_CLIENT_ID=bustly-desktop
# BUSTLY_SUPABASE_URL=https://<project-ref>.supabase.co
# BUSTLY_SUPABASE_ANON_KEY=...
#
# AWS staging infra
# OPENCLAW_AWS_REGION=ap-southeast-1
# OPENCLAW_ECS_CLUSTER_NAME=openclaw-staging-cluster
# OPENCLAW_VPC_ID=vpc-xxxxxxxx
# OPENCLAW_PUBLIC_SUBNET_IDS_CSV=subnet-aaa,subnet-bbb
# OPENCLAW_RUNTIME_SECURITY_GROUP_ID=sg-xxxxxxxx
# OPENCLAW_ECS_TASK_EXECUTION_ROLE_ARN=arn:aws:iam::<account-id>:role/...
# OPENCLAW_ECS_TASK_ROLE_ARN=arn:aws:iam::<account-id>:role/...
# OPENCLAW_CLOUDWATCH_LOG_GROUP_NAME=/bustly/openclaw/staging
# OPENCLAW_WORKSPACE_RUNTIME_TABLE_NAME=openclaw-staging-workspace-runtime
# OPENCLAW_ALB_LISTENER_ARN_FOR_RULES=arn:aws:elasticloadbalancing:...
# OPENCLAW_ALB_DNS_NAME=openclaw-staging-alb-xxxx.ap-southeast-1.elb.amazonaws.com
# OPENCLAW_EFS_FILE_SYSTEM_ID=fs-xxxxxxxx

# -----------------------------------------------------------------------------
# Model provider API keys (set at least one)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# OPENROUTER_API_KEY=sk-or-...
# OPENCLAW_LIVE_OPENAI_KEY=sk-...
# OPENCLAW_LIVE_ANTHROPIC_KEY=sk-ant-...
# OPENCLAW_LIVE_GEMINI_KEY=...
# OPENAI_API_KEY_1=...
# ANTHROPIC_API_KEY_1=...
# GEMINI_API_KEY_1=...
# GOOGLE_API_KEY=...
# OPENAI_API_KEYS=sk-1,sk-2
# ANTHROPIC_API_KEYS=sk-ant-1,sk-ant-2
# GEMINI_API_KEYS=key-1,key-2

# Optional additional providers
# ZAI_API_KEY=...
# AI_GATEWAY_API_KEY=...
# MINIMAX_API_KEY=...
# SYNTHETIC_API_KEY=...

# -----------------------------------------------------------------------------
# Channels (only set what you enable)
# -----------------------------------------------------------------------------
# TELEGRAM_BOT_TOKEN=123456:ABCDEF...
# DISCORD_BOT_TOKEN=...
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...

# Optional channel env fallbacks
# MATTERMOST_BOT_TOKEN=...
# MATTERMOST_URL=https://chat.example.com
# ZALO_BOT_TOKEN=...
# OPENCLAW_TWITCH_ACCESS_TOKEN=oauth:...

# -----------------------------------------------------------------------------
# Tools + voice/media (optional)
# -----------------------------------------------------------------------------
# BRAVE_API_KEY=...
# PERPLEXITY_API_KEY=pplx-...
# FIRECRAWL_API_KEY=...

# ELEVENLABS_API_KEY=...
# XI_API_KEY=...  # alias for ElevenLabs
# DEEPGRAM_API_KEY=...
